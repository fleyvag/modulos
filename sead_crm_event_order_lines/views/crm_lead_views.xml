<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_inherit_event_lines" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.event.lines</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="event_id" placeholder="Evento"/>
            </field>

            <xpath expr="//page[field[@name='description']]" position="before">
                <page name="order_lines" string="Línea de Pedido">
                    <field name="custom_order_line_ids" nolabel="1">
                        <tree editable="bottom" multi_edit="1">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id" required="1"/>
                            <field name="name" placeholder="Descripción"/>
                            <field name="quantity"/>
                            <field name="price_unit"/>
                            <field name="tax_ids" widget="many2many_tags"/>
                            <field name="subtotal" sum="Total"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
