<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_extra_names_form" model="ir.ui.view">
        <field name="name">res.partner.extra.names.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="razon_social" placeholder="Razón social"/>
                <field name="nombre_comercial" placeholder="Nombre comercial"/>
            </xpath>
        </field>
    </record>
</odoo>
