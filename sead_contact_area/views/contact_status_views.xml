<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contact_status_tree" model="ir.ui.view">
        <field name="name">contact.status.tree</field>
        <field name="model">contact.status</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_contact_status_form" model="ir.ui.view">
        <field name="name">contact.status.form</field>
        <field name="model">contact.status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_contact_status_search" model="ir.ui.view">
        <field name="name">contact.status.search</field>
        <field name="model">contact.status</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_contact_status" model="ir.actions.act_window">
        <field name="name">Estatus</field>
        <field name="res_model">contact.status</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>Define los estatus que pueden asignarse a los contactos.</p>
        </field>
    </record>
</odoo>
