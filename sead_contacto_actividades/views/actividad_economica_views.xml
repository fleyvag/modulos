<odoo>
    <record id="view_actividad_economica_tree" model="ir.ui.view">
        <field name="name">actividad.economica.tree</field>
        <field name="model">actividad.economica</field>
        <field name="arch" type="xml">
            <tree>
                <field name="actividad"/>
                <field name="actividad_padre_id"/>
                <field name="nombre_completo"/>
            </tree>
        </field>
    </record>

    <record id="view_actividad_economica_form" model="ir.ui.view">
        <field name="name">actividad.economica.form</field>
        <field name="model">actividad.economica</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="actividad"/>
                        <field name="actividad_padre_id"/>
                        <field name="nombre_completo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_actividad_economica" model="ir.actions.act_window">
        <field name="name">Actividades Económicas</field>
        <field name="res_model">actividad.economica</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
