<odoo>
    <record id="view_actividad_padre_tree" model="ir.ui.view">
        <field name="name">actividad.padre.tree</field>
        <field name="model">actividad.padre</field>
        <field name="arch" type="xml">
            <tree>
                <field name="actividad"/>
            </tree>
        </field>
    </record>

    <record id="view_actividad_padre_form" model="ir.ui.view">
        <field name="name">actividad.padre.form</field>
        <field name="model">actividad.padre</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="actividad"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_actividad_padre" model="ir.actions.act_window">
        <field name="name">Actividades Padre</field>
        <field name="res_model">actividad.padre</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
