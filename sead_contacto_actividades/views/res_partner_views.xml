<odoo>
    <record id="view_partner_form_inherit_actividad" model="ir.ui.view">
        <field name="name">res.partner.form.actividad</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <page name="internal_notes" position="after">
                <page name="actividad_economica" string="Actividad Económica">
                    <group>
                        <field name="actividad_economica_id"/>
                    </group>
                </page>
            </page>
        </field>
    </record>
</odoo>
